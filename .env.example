# Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# React Environment
REACT_APP_ENV=development
REACT_APP_VERSION=0.1.0

# API Configuration (if needed)
# REACT_APP_API_URL=https://api.example.com
# REACT_APP_API_TIMEOUT=30000

# Analytics (if needed)
# REACT_APP_ANALYTICS_ID=UA-XXXXXXXXX-X

# Feature Flags (if needed)
# REACT_APP_ENABLE_BETA_FEATURES=false

# Note: Variables prefixed with REACT_APP_ are embedded in the bundle during build
# Never put sensitive data in environment variables visible to the client
